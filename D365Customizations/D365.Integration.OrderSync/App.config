<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.2" />
  </startup>
  <appSettings>
    <!-- Replace with your Dataverse connection string (OAuth). Do not commit secrets. -->
    <add key="CrmConnection" value="" />
    <!-- Full URL to POST JSON orders (Azure Function local: func start → http://localhost:7071/api/orders). -->
    <add key="OrderApiUrl" value="http://localhost:7071/api/orders" />
    <!-- When true, uses MockExternalApiClient and ignores OrderApiUrl. -->
    <add key="UseMockApi" value="true" />
  </appSettings>
</configuration>
